generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  mongodbUrl    String?   
  
  // Custom user fields
  otp           String?
  isVerified    Boolean   @default(false)
  otpExpiresAt  DateTime?

  // Gamification fields
  xp            Int       @default(0)
  level         Int       @default(1)
  streak        Int       @default(0)
  lastActivityAt DateTime?

  accounts      Account[]
  sessions      Session[]
  
  // Relations
  tests            Test[]
  attempts         TestAttempt[]
  descriptiveTests DescriptiveTest[]
  achievements     Achievement[]
  hostedDuels      DuelRoom[] @relation("HostedDuels")
  guestDuels       DuelRoom[] @relation("GuestDuels")
  flashcards       Flashcard[]
  questionAudits   QuestionAudit[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------ App Specific Models ------

model PdfDocument {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  url         String
  fileSize    Int?
  pageCount   Int?
  testId      String   @db.ObjectId
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
}

model Test {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  duration    Int           // in minutes
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId      String        @db.ObjectId
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  questions   Question[]
  attempts    TestAttempt[]
  pdfs        PdfDocument[] // Context/PYQ PDFs
  duels       DuelRoom[]

  @@index([userId])
}

model Question {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  question      String
  options       String[]
  correctAnswer Int
  explanation   String?
  difficulty    String   @default("medium")
  
  flashcards    Flashcard[]
  audits        QuestionAudit[]

  testId        String   @db.ObjectId
  test          Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
}

model TestAttempt {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  score       Int
  answers     Int[]
  completed   Boolean  @default(false)
  xpEarned    Int?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  userId      String   @db.ObjectId
  testId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([testId, score, createdAt])
}

model DescriptiveTest {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  examName       String
  question       String
  answer         String
  wordCount      Int
  timeLimit      Int      // in minutes
  timeTaken      Int      // in seconds
  feedback       String
  score          Float
  suggestions    String[]
  strengths      String[]
  areasToImprove String[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Achievement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  icon        String   // Emoji or icon name
  unlockedAt  DateTime @default(now())

  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DuelRoom {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  roomCode    String   @unique
  testId      String   @db.ObjectId
  hostId      String   @db.ObjectId
  guestId     String?  @db.ObjectId
  status      String   @default("WAITING") // WAITING, ACTIVE, FINISHED
  
  hostProgress  Int    @default(0) // 0-100 percentage
  guestProgress Int    @default(0) // 0-100 percentage
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  test        Test     @relation(fields: [testId], references: [id])
  host        User     @relation("HostedDuels", fields: [hostId], references: [id])
  guest       User?    @relation("GuestDuels", fields: [guestId], references: [id])
}

model Flashcard {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  questionId    String   @db.ObjectId
  
  // SRS Fields (SM-2)
  interval      Int      @default(0) // Interval in days
  repetition    Int      @default(0) // Iteration number
  easeFactor    Float    @default(2.5) // Difficulty multiplier
  nextReviewAt  DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextReviewAt])
}

model QuestionAudit {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId  String   @db.ObjectId
  userId      String   @db.ObjectId
  reason      String   // E.g., Incorrect option, typo, bad explanation
  details     String?
  status      String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}
